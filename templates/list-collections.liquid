<section class="fz-collections-list section">
  <div class="container">
    <header class="fz-collections-list__header">
      <h1>Categories</h1>
      <p>Explore every FlyntraZone collection in one place.</p>
    </header>

    <div class="fz-collections-grid" role="list">
      {% for collection in collections %}
        <article class="fz-collection-card" role="listitem">
          <a class="fz-collection-card__link" href="{{ collection.url }}">
            <div class="fz-collection-card__media">
              {% if collection.featured_image %}
                <img
                  src="{{ collection.featured_image | image_url: width: 1200 }}"
                  alt="{{ collection.title | escape }}"
                  loading="lazy"
                >
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'fz-collection-card__placeholder' }}
              {% endif %}
              <div class="fz-collection-card__overlay"></div>
            </div>

            <div class="fz-collection-card__content">
              <h2>{{ collection.title }}</h2>
              <p>{{ collection.all_products_count }} products</p>
              <span class="fz-collection-card__cta">Shop Now</span>
            </div>
          </a>
        </article>
      {% else %}
        <p class="fz-collections-list__empty">No collections found yet.</p>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .fz-collections-list {
    background: #ececec;
    color: #111111;
  }

  .fz-collections-list__header {
    margin-bottom: 1.4rem;
  }

  .fz-collections-list__header h1 {
    margin: 0;
    font-family: "Bebas Neue", "Arial Narrow", sans-serif;
    font-size: clamp(2rem, 6vw, 4rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .fz-collections-list__header p {
    margin: 0.25rem 0 0;
    color: #555;
    font-size: 0.95rem;
  }

  .fz-collections-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .fz-collection-card__link {
    position: relative;
    display: block;
    color: #ffffff;
    overflow: hidden;
    min-height: 460px;
    background: #111;
  }

  .fz-collection-card__media {
    position: absolute;
    inset: 0;
  }

  .fz-collection-card__media img,
  .fz-collection-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 450ms ease;
  }

  .fz-collection-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.16) 35%, rgba(0, 0, 0, 0.62) 100%);
    transition: background-color 260ms ease;
  }

  .fz-collection-card__content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: 1.2rem 1.1rem 1rem;
  }

  .fz-collection-card__content h2 {
    margin: 0;
    font-family: "Bebas Neue", "Arial Narrow", sans-serif;
    font-size: clamp(1.6rem, 3.4vw, 2.4rem);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #ffffff;
  }

  .fz-collection-card__content p {
    margin: 0.2rem 0 0.7rem;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
  }

  .fz-collection-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.45rem;
    padding: 0.62rem 1rem;
    background: #ff4500;
    color: #ffffff;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transform: translateY(120%);
    opacity: 0;
    transition: transform 300ms ease, opacity 300ms ease;
  }

  .fz-collection-card__link:hover .fz-collection-card__media img {
    transform: scale(1.06);
  }

  .fz-collection-card__link:hover .fz-collection-card__overlay {
    background-color: rgba(0, 0, 0, 0.35);
  }

  .fz-collection-card__link:hover .fz-collection-card__cta {
    transform: translateY(0);
    opacity: 1;
  }

  .fz-collections-list__empty {
    margin: 0;
    color: #444;
  }

  @media (max-width: 989px) {
    .fz-collections-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 749px) {
    .fz-collections-grid {
      grid-template-columns: 1fr;
    }

    .fz-collection-card__link {
      min-height: 380px;
    }
  }
</style>
