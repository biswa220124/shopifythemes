<section class="fz-mood section">
  <div class="container">

    <div class="fz-mood__header">
      <p class="fz-mood__eyebrow">Curated Vibes</p>
      <h2 class="fz-mood__title">Match The Mood</h2>
      <p class="fz-mood__sub">Everyday Bestsellers</p>
      <div class="fz-section-divider"></div>
    </div>

    <div class="fz-mood__grid">

      <!-- CARD 1 -->
      <a href="/products/navy-blue-polo-t-shirt" class="fz-mood__card">
        <img src="https://images.unsplash.com/photo-1516826957135-700dedea698c?q=80&w=800" alt="Everyday Basics" loading="lazy" />
        <div class="fz-mood__overlay">
          <span class="fz-mood__label">Everyday</span>
          <h3 class="fz-mood__card-title">Basics</h3>
        </div>
      </a>

      <!-- CARD 2 -->
      <a href="products/everyday-neutral-sweatshirt" class="fz-mood__card">
        <img src="https://images.unsplash.com/photo-1503342217505-b0a15ec3261c?q=80&w=800" alt="Women Everyday Basics" loading="lazy" />
        <div class="fz-mood__overlay">
          <span class="fz-mood__label">Women Everyday</span>
          <h3 class="fz-mood__card-title">Basics</h3>
        </div>
      </a>

      <!-- CARD 3 -->
      <a href="/products/summer-breeze-t-shirt" class="fz-mood__card">
        <img src="https://images.unsplash.com/photo-1512436991641-6745cdb1723f?q=80&w=800" alt="Travel Mood" loading="lazy" />
        <div class="fz-mood__overlay">
          <span class="fz-mood__label">Travel</span>
          <h3 class="fz-mood__card-title">Mood</h3>
        </div>
      </a>

      <!-- CARD 4 -->
      <a href="/products/oversized-drop-shoulder-hoodie" class="fz-mood__card">
        <img src="https://images.unsplash.com/photo-1520975661595-6453be3f7070?q=80&w=800" alt="Ready To Move" loading="lazy" />
        <div class="fz-mood__overlay">
          <span class="fz-mood__label">Ready To</span>
          <h3 class="fz-mood__card-title">Move</h3>
        </div>
      </a>

    </div>

  </div>
</section>

<style>
/* ===========================
   MOOD SECTION — Unified Theme
   =========================== */
.fz-mood {
  padding: clamp(60px, 8vw, 100px) 0;
  background: #ffffff;
}

.fz-mood__header {
  text-align: center;
  margin-bottom: 48px;
}

.fz-mood__eyebrow {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #d4886b;
  margin: 0 0 10px;
}

.fz-mood__title {
  font-family: "Bebas Neue", "Arial Narrow", sans-serif;
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 400;
  color: #2c2320;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin: 0 0 10px;
}

.fz-mood__sub {
  font-size: 0.88rem;
  color: #8c7b73;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin: 0 0 20px;
}

/* GRID */
.fz-mood__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

/* CARD */
.fz-mood__card {
  position: relative;
  overflow: hidden;
  border-radius: 20px;
  text-decoration: none;
  border: 1px solid rgba(139, 92, 246, 0.1);
  box-shadow: 0 2px 16px rgba(44, 35, 32, 0.08);
  transition: transform 0.35s ease, box-shadow 0.35s ease;
}

.fz-mood__card:hover {
  transform: translateY(-8px);
  box-shadow: 0 16px 48px rgba(212, 136, 107, 0.18);
  border-color: rgba(139, 92, 246, 0.25);
}

/* IMAGE */
.fz-mood__card img {
  width: 100%;
  height: 420px;
  object-fit: cover;
  transition: transform 0.55s ease;
}

/* HOVER ZOOM */
.fz-mood__card:hover img {
  transform: scale(1.08);
}

/* OVERLAY */
.fz-mood__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 24px;
  background: linear-gradient(to top, rgba(44, 35, 32, 0.85), rgba(44, 35, 32, 0.35) 60%, transparent);
}

/* TEXT */
.fz-mood__label {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.85);
}

.fz-mood__card-title {
  font-family: "Bebas Neue", "Arial Narrow", sans-serif;
  font-size: clamp(1.4rem, 2vw, 1.8rem);
  margin-top: 4px;
  font-weight: 400;
  color: #ffffff;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

/* SHOP NOW HOVER TEXT */
.fz-mood__card::after {
  content: "SHOP NOW →";
  position: absolute;
  bottom: 24px;
  right: 24px;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #fff;
  background: rgba(212, 136, 107, 0.6);
  backdrop-filter: blur(4px);
  padding: 6px 14px;
  border-radius: 20px;
  opacity: 0;
  transform: translateY(6px);
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.fz-mood__card:hover::after {
  opacity: 1;
  transform: translateY(0);
}

/* MOBILE */
@media (max-width: 989px) {
  .fz-mood__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 749px) {
  .fz-mood {
    padding: 60px 0;
  }
  .fz-mood__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .fz-mood__card img {
    height: 280px;
  }
}
</style>

{% schema %}
{
  "name": "Mood Section",
  "presets": [
    {
      "name": "Mood Section"
    }
  ]
}
{% endschema %}