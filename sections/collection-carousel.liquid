<section class="fz-col-carousel">
  <div class="container">

    <div class="fz-col-carousel__header">
      <p class="fz-col-carousel__eyebrow">Discover More</p>
      <h2 class="fz-col-carousel__title">Explore Collections</h2>
      <div class="fz-section-divider"></div>
    </div>

    <div class="fz-col-carousel__track" id="fz-carousel">

      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}

        {% if collection != blank %}
          <a href="{{ collection.url }}" class="fz-col-carousel__card">

            {% if collection.image %}
              <img src="{{ collection.image | image_url: width: 800 }}" alt="{{ collection.title }}" loading="lazy">
            {% else %}
              <div class="fz-col-carousel__placeholder">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                <span>No Image</span>
              </div>
            {% endif %}

            <div class="fz-col-carousel__overlay">
              <h3>{{ collection.title }}</h3>
              <span class="fz-col-carousel__cta">Shop Now →</span>
            </div>

          </a>
        {% endif %}
      {% endfor %}

    </div>

  </div>
</section>

<style>
/* ===========================
   COLLECTION CAROUSEL — Unified Theme
   =========================== */
.fz-col-carousel {
  padding: clamp(60px, 8vw, 100px) 0;
  background: #ffffff;
}

.fz-col-carousel__header {
  text-align: center;
  margin-bottom: 48px;
}

.fz-col-carousel__eyebrow {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #d4886b;
  margin: 0 0 10px;
}

.fz-col-carousel__title {
  font-family: "Bebas Neue", "Arial Narrow", sans-serif;
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 400;
  color: #2c2320;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin: 0 0 20px;
}

/* CAROUSEL */
.fz-col-carousel__track {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  padding-bottom: 8px;
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.fz-col-carousel__track::-webkit-scrollbar {
  display: none;
}

/* CARD */
.fz-col-carousel__card {
  min-width: 300px;
  flex: 0 0 auto;
  position: relative;
  overflow: hidden;
  border-radius: 20px;
  scroll-snap-align: start;
  text-decoration: none;
  border: 1px solid rgba(139, 92, 246, 0.1);
  box-shadow: 0 2px 16px rgba(44, 35, 32, 0.08);
  transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
}

.fz-col-carousel__card:hover {
  transform: translateY(-6px);
  box-shadow: 0 16px 48px rgba(212, 136, 107, 0.18);
  border-color: rgba(139, 92, 246, 0.3);
}

.fz-col-carousel__card img {
  width: 100%;
  height: 380px;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.fz-col-carousel__card:hover img {
  transform: scale(1.06);
}

/* OVERLAY */
.fz-col-carousel__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 22px 24px;
  background: linear-gradient(to top, rgba(44, 35, 32, 0.85), rgba(44, 35, 32, 0.35) 60%, transparent);
  color: #fff;
}

.fz-col-carousel__overlay h3 {
  font-family: "Bebas Neue", "Arial Narrow", sans-serif;
  font-size: clamp(1.2rem, 2vw, 1.6rem);
  font-weight: 400;
  color: #ffffff;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin: 0 0 4px;
}

.fz-col-carousel__cta {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.8);
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.fz-col-carousel__card:hover .fz-col-carousel__cta {
  opacity: 1;
  transform: translateY(0);
}

/* PLACEHOLDER */
.fz-col-carousel__placeholder {
  height: 380px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  background: linear-gradient(135deg, #f5f0eb, #e8e6f6);
  color: #8c7b73;
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* MOBILE */
@media (max-width: 749px) {
  .fz-col-carousel {
    padding: 60px 0;
  }
  .fz-col-carousel__card {
    min-width: 80%;
  }
  .fz-col-carousel__card img {
    height: 300px;
  }
  .fz-col-carousel__placeholder {
    height: 300px;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  var carousel = document.getElementById("fz-carousel");
  if (!carousel) return;

  var scrollAmount = 0;
  var cardWidth = 320;

  function autoSlide() {
    scrollAmount += cardWidth;

    if (scrollAmount >= carousel.scrollWidth - carousel.clientWidth) {
      scrollAmount = 0;
    }

    carousel.scrollTo({
      left: scrollAmount,
      behavior: "smooth"
    });
  }

  var interval = setInterval(autoSlide, 3000);

  carousel.addEventListener("mouseenter", function() { clearInterval(interval); });
  carousel.addEventListener("mouseleave", function() {
    interval = setInterval(autoSlide, 3000);
  });
});
</script>

{% schema %}
{
  "name": "Collection Carousel",
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select collection"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Collection Carousel"
    }
  ]
}
{% endschema %}