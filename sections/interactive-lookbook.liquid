<section class="fz-interactive-lookbook" data-reveal>
  <div class="container">
    <div class="fz-interactive-lookbook__header">
      <h2 class="fz-interactive-lookbook__title">{{ section.settings.heading | default: "Shop The Look" }}</h2>
      <p class="fz-interactive-lookbook__subtitle">{{ section.settings.subheading | default: "Curated styles for the modern wardrobe. Hover to explore." }}</p>
    </div>

    <div class="fz-interactive-lookbook__image-wrap">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | image_url: width: 1400 }}" alt="Lookbook" class="fz-interactive-lookbook__img" loading="lazy">
      {% else %}
        <img src="{{ 'interactive-lookbook.png' | asset_url }}" alt="Lookbook" class="fz-interactive-lookbook__img" loading="lazy">
      {% endif %}

      {% for block in section.blocks %}
        <div class="fz-hotspot" style="top: {{ block.settings.top_position }}%; left: {{ block.settings.left_position }}%;">
          <button class="fz-hotspot__dot" aria-label="View product details">
            <span class="fz-hotspot__ring"></span>
            <span class="fz-hotspot__center"></span>
          </button>
          
          <div class="fz-hotspot__tooltip">
            {% if block.settings.product != blank %}
              {% assign product = all_products[block.settings.product] %}
              <div class="fz-hotspot__product">
                <img src="{{ product.featured_image | image_url: width: 100 }}" alt="{{ product.title }}" class="fz-hotspot__product-img">
                <div class="fz-hotspot__product-info">
                  <h4 class="fz-hotspot__product-title">{{ product.title }}</h4>
                  <p class="fz-hotspot__product-price">{{ product.price | money }}</p>
                  <a href="{{ product.url }}" class="fz-hotspot__product-link">Shop Now</a>
                </div>
              </div>
            {% else %}
              <div class="fz-hotspot__product">
                <div class="fz-hotspot__product-placeholder"></div>
                <div class="fz-hotspot__product-info">
                  <h4 class="fz-hotspot__product-title">Oversized Hoodie</h4>
                  <p class="fz-hotspot__product-price">Rs. 2,999</p>
                  <a href="/collections/all" class="fz-hotspot__product-link">Shop Now</a>
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
      
      {% if section.blocks.size == 0 %}
      <!-- Placeholder Demo Hotspots -->
      <div class="fz-hotspot" style="top: 35%; left: 48%;">
        <button class="fz-hotspot__dot" aria-label="View product details">
          <span class="fz-hotspot__ring"></span><span class="fz-hotspot__center"></span>
        </button>
        <div class="fz-hotspot__tooltip">
          <div class="fz-hotspot__product">
            <div class="fz-hotspot__product-placeholder" style="background:#111;"></div>
            <div class="fz-hotspot__product-info">
              <h4 class="fz-hotspot__product-title">Onyx Signature Hoodie</h4>
              <p class="fz-hotspot__product-price">Rs. 3,499</p>
              <a href="/collections/all" class="fz-hotspot__product-link">Shop Now</a>
            </div>
          </div>
        </div>
      </div>
      <div class="fz-hotspot" style="top: 65%; left: 55%;">
        <button class="fz-hotspot__dot" aria-label="View product details">
          <span class="fz-hotspot__ring"></span><span class="fz-hotspot__center"></span>
        </button>
        <div class="fz-hotspot__tooltip">
          <div class="fz-hotspot__product">
            <div class="fz-hotspot__product-placeholder" style="background:#222;"></div>
            <div class="fz-hotspot__product-info">
              <h4 class="fz-hotspot__product-title">Tailored Cargo Pants</h4>
              <p class="fz-hotspot__product-price">Rs. 2,899</p>
              <a href="/collections/all" class="fz-hotspot__product-link">Shop Now</a>
            </div>
          </div>
        </div>
      </div>
      {% endif %}

    </div>
  </div>
</section>

<style>
.fz-interactive-lookbook {
  padding: clamp(60px, 8vw, 100px) 0;
  background-color: var(--color-secondary, #f8f9fa);
}

.fz-interactive-lookbook__header {
  text-align: center;
  margin-bottom: 40px;
}

.fz-interactive-lookbook__title {
  font-family: var(--font-heading, "Playfair Display", serif);
  font-size: clamp(2.2rem, 4vw, 3.5rem);
  color: var(--color-primary, #0d0e12);
  margin: 0 0 12px;
}

.fz-interactive-lookbook__subtitle {
  color: var(--color-muted, #6b6b8a);
  font-size: 1.1rem;
  max-width: 600px;
  margin: 0 auto;
}

.fz-interactive-lookbook__image-wrap {
  position: relative;
  max-width: 1000px;
  margin: 0 auto;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 20px 40px rgba(0,0,0,0.15);
}

.fz-interactive-lookbook__img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}

.fz-hotspot {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 10;
}

.fz-hotspot__dot {
  position: relative;
  width: 28px;
  height: 28px;
  background: transparent;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.fz-hotspot__center {
  width: 12px;
  height: 12px;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  z-index: 2;
  transition: transform 0.3s ease;
}

.fz-hotspot__ring {
  position: absolute;
  inset: 0;
  border: 2px solid rgba(255,255,255,0.6);
  border-radius: 50%;
  animation: hotspot-pulse 2s infinite ease-out;
}

@keyframes hotspot-pulse {
  0% { transform: scale(0.8); opacity: 1; }
  100% { transform: scale(2.5); opacity: 0; }
}

.fz-hotspot:hover .fz-hotspot__center {
  transform: scale(1.3);
}

.fz-hotspot__tooltip {
  position: absolute;
  bottom: calc(100% + 15px);
  left: 50%;
  transform: translateX(-50%) translateY(10px);
  background: #ffffff;
  border-radius: 8px;
  padding: 12px;
  width: 240px;
  opacity: 0;
  visibility: hidden;
  box-shadow: 0 12px 30px rgba(0,0,0,0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none;
}

.fz-hotspot__tooltip::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  border-width: 8px;
  border-style: solid;
  border-color: #ffffff transparent transparent transparent;
}

.fz-hotspot:hover .fz-hotspot__tooltip {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0);
  pointer-events: auto;
}

.fz-hotspot__product {
  display: flex;
  gap: 12px;
  align-items: center;
}

.fz-hotspot__product-img,
.fz-hotspot__product-placeholder {
  width: 60px;
  height: 80px;
  object-fit: cover;
  border-radius: 4px;
}

.fz-hotspot__product-placeholder {
  background: #eaeaea;
}

.fz-hotspot__product-info {
  flex: 1;
}

.fz-hotspot__product-title {
  font-family: var(--font-body, sans-serif);
  font-size: 0.85rem;
  font-weight: 600;
  color: #0d0e12;
  margin: 0 0 4px;
  line-height: 1.3;
}

.fz-hotspot__product-price {
  font-size: 0.85rem;
  color: #6b6b8a;
  margin: 0 0 8px;
}

.fz-hotspot__product-link {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--color-accent, #d4af37);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  text-decoration: none;
  border-bottom: 1px solid currentColor;
}

.fz-hotspot__product-link:hover {
  color: #0d0e12;
}
</style>

{% schema %}
{
  "name": "Interactive Lookbook",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop The Look"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated styles for the modern wardrobe. Hover to explore."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lookbook Image"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Product Hotspot",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "range",
          "id": "top_position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Vertical Position",
          "default": 30
        },
        {
          "type": "range",
          "id": "left_position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Horizontal Position",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Interactive Lookbook",
      "blocks": [
        { "type": "hotspot", "settings": { "top_position": 35, "left_position": 48 } },
        { "type": "hotspot", "settings": { "top_position": 65, "left_position": 55 } }
      ]
    }
  ]
}
{% endschema %}
