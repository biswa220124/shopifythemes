<section class="fz-main-cart section">
  <div class="container">
    <h1>Your Bag</h1>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <div class="fz-main-cart__layout">
          <div class="fz-main-cart__items">
            {% for item in cart.items %}
              <article class="fz-main-cart__item">
                <a class="fz-main-cart__image" href="{{ item.url }}">
                  {% if item.image %}
                    <img
                      src="{{ item.image | image_url: width: 360 }}"
                      alt="{{ item.image.alt | default: item.product.title | escape }}"
                      loading="lazy"
                    >
                  {% endif %}
                </a>

                <div class="fz-main-cart__content">
                  <h2><a href="{{ item.url }}">{{ item.product.title }}</a></h2>

                  {% if item.product.has_only_default_variant == false %}
                    <p class="fz-main-cart__variant">{{ item.variant.title }}</p>
                  {% endif %}

                  <p class="fz-main-cart__price">{{ item.final_line_price | money }}</p>

                  <div class="fz-main-cart__actions">
                    <label for="Quantity-{{ item.key }}">Qty</label>
                    <input
                      id="Quantity-{{ item.key }}"
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                    >
                    <a href="{{ item.url_to_remove }}" class="fz-main-cart__remove">Remove</a>
                  </div>
                </div>
              </article>
            {% endfor %}
          </div>

          <aside class="fz-main-cart__summary">
            <h3>Order Summary</h3>
            <p class="fz-main-cart__subtotal">
              <span>Subtotal</span>
              <strong>{{ cart.total_price | money }}</strong>
            </p>

            <label for="CartNote">Order note</label>
            <textarea id="CartNote" name="note" rows="4">{{ cart.note }}</textarea>

            <button type="submit" name="update" class="fz-main-cart__update">Update Bag</button>
            <button type="submit" name="checkout" class="fz-main-cart__checkout">Checkout</button>
          </aside>
        </div>
      </form>
    {% else %}
      <div class="fz-main-cart__empty">
        <p>Your bag is currently empty.</p>
        <a href="{{ routes.collections_url }}">Continue shopping</a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .fz-main-cart {
    background: #ececec;
    color: #111111;
  }
  .fz-main-cart h1 {
    margin: 0 0 1.2rem;
    font-family: "Bebas Neue", "Arial Narrow", sans-serif;
    font-size: clamp(2rem, 6vw, 3.8rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .fz-main-cart__layout {
    display: grid;
    grid-template-columns: 1.6fr 0.9fr;
    gap: 1.4rem;
  }
  .fz-main-cart__items {
    display: grid;
    gap: 0.85rem;
  }
  .fz-main-cart__item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 0.9rem;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(17, 17, 17, 0.1);
    padding: 0.75rem;
  }
  .fz-main-cart__image img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
  }
  .fz-main-cart__content h2 {
    margin: 0 0 0.3rem;
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: 1rem;
    font-weight: 500;
  }
  .fz-main-cart__content h2 a {
    color: #111111;
    text-decoration: none;
  }
  .fz-main-cart__variant {
    margin: 0 0 0.35rem;
    color: #555;
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .fz-main-cart__price {
    margin: 0 0 0.55rem;
    color: #ff4500;
    font-weight: 700;
  }
  .fz-main-cart__actions {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .fz-main-cart__actions label {
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .fz-main-cart__actions input {
    width: 4.4rem;
    min-height: 2rem;
    border: 1px solid #111111;
    background: transparent;
    padding: 0.2rem 0.45rem;
  }
  .fz-main-cart__remove {
    margin-left: 0.4rem;
    color: #111111;
    font-size: 0.8rem;
    text-decoration: underline;
  }
  .fz-main-cart__summary {
    background: #111111;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 1rem;
    height: fit-content;
  }
  .fz-main-cart__summary h3 {
    margin: 0 0 0.8rem;
    color: #ffffff;
    font-family: "Bebas Neue", "Arial Narrow", sans-serif;
    font-size: 1.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .fz-main-cart__subtotal {
    display: flex;
    justify-content: space-between;
    gap: 0.7rem;
    margin: 0 0 0.9rem;
  }
  .fz-main-cart__subtotal strong {
    color: #ff4500;
  }
  .fz-main-cart__summary label {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .fz-main-cart__summary textarea {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: transparent;
    color: #ffffff;
    padding: 0.55rem;
    margin-bottom: 0.75rem;
  }
  .fz-main-cart__update,
  .fz-main-cart__checkout {
    width: 100%;
    min-height: 2.65rem;
    border: 1px solid transparent;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .fz-main-cart__update {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.4);
    color: #ffffff;
    margin-bottom: 0.55rem;
  }
  .fz-main-cart__checkout {
    background: #ff4500;
    color: #ffffff;
    border-color: #ff4500;
  }
  .fz-main-cart__empty {
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(17, 17, 17, 0.1);
    padding: 1rem;
  }
  .fz-main-cart__empty p {
    margin: 0 0 0.75rem;
  }
  .fz-main-cart__empty a {
    color: #ff4500;
    text-decoration: none;
    font-weight: 600;
  }
  @media (max-width: 989px) {
    .fz-main-cart__layout {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 749px) {
    .fz-main-cart__item {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}
