<header class="fz-header" data-header>
  <div class="fz-header__inner container">
    <div class="fz-header__left">
      <button class="fz-header__menu-toggle" type="button" aria-label="Open menu" data-menu-open>
        <span></span>
        <span></span>
        <span></span>
      </button>

      <a class="fz-header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {% if section.settings.logo != blank %}
          <img
            src="{{ section.settings.logo | image_url: width: section.settings.logo_width | default: 220 }}"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            width="{{ section.settings.logo_width }}"
            height="auto"
            loading="eager"
          >
        {% else %}
          <!-- New Premium Store Logo -->
          <img class="fz-logo-img" src="{{ 'logo.png' | asset_url }}" alt="FlyntraZone Luxury Store" loading="eager" width="220" height="auto">
        {% endif %}
      </a>
    </div>

    <nav class="fz-header__nav" aria-label="Main navigation">
      <ul class="fz-header__menu">
        <li>
          <a href="{{ routes.root_url }}" {% if request.path == '/' %}aria-current="page"{% endif %}>Home</a>
        </li>
        <li>
          <a href="/collections" {% if request.path contains '/collections' %}aria-current="page"{% endif %}>Categories</a>
        </li>
        <li>
          <a href="/pages/track-order" {% if request.path == '/pages/track-order' %}aria-current="page"{% endif %}>Track Order</a>
        </li>
      </ul>
    </nav>

    <div class="fz-header__right">
      <a class="fz-header__cart" href="/cart" aria-label="Cart ({{ cart.item_count }} items)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        {% if cart.item_count > 0 %}
          <span class="fz-header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>
  </div>
</header>

<div class="fz-mobile-drawer" data-menu-drawer>
  <div class="fz-mobile-drawer__overlay" data-menu-close></div>
  <aside class="fz-mobile-drawer__panel" aria-label="Mobile menu">
    <div class="fz-mobile-drawer__header">
      <a href="{{ routes.root_url }}" class="fz-mobile-drawer__logo">
        <!-- Mobile Premium Store Logo -->
        <img class="fz-logo-img" src="{{ 'logo.png' | asset_url }}" alt="FlyntraZone Mobile" loading="eager" width="180" height="auto">
      </a>
      <button class="fz-mobile-drawer__close" type="button" aria-label="Close menu" data-menu-close>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <nav>
      <ul class="fz-mobile-drawer__menu">
        <li>
          <a href="{{ routes.root_url }}" {% if request.path == '/' %}aria-current="page"{% endif %}>Home</a>
        </li>
        <li>
          <a href="/collections" {% if request.path contains '/collections' %}aria-current="page"{% endif %}>Categories</a>
        </li>
        <li>
          <a href="/pages/track-order" {% if request.path == '/pages/track-order' %}aria-current="page"{% endif %}>Track Order</a>
        </li>
      </ul>
    </nav>

    <div class="fz-mobile-drawer__footer">
      <a href="/cart" class="fz-mobile-drawer__cart-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        View Cart ({{ cart.item_count }})
      </a>
    </div>
  </aside>
</div>

<style>
  .fz-header {
    position: fixed;
    top: 40px;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 50;
    background: rgba(10, 2, 26, 0.82);
    border-bottom: 1px solid rgba(139, 92, 246, 0.2);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    transform: translateY(calc(-100% - 8px));
    opacity: 0;
    pointer-events: none;
    transition: transform 0.4s ease, opacity 0.4s ease;
  }

  .fz-header.is-visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .fz-header.is-scrolled {
    background: rgba(10, 2, 26, 0.92);
    border-bottom-color: rgba(139, 92, 246, 0.3);
  }

  .fz-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 72px;
    gap: 1rem;
  }

  .fz-header__left {
    display: flex;
    align-items: center;
    justify-self: start;
    gap: 0.8rem;
  }

  .fz-header__logo {
    display: flex;
    align-items: center;
    color: #ffffff;
    font-family: var(--font-heading);
    letter-spacing: 0.04em;
    text-transform: none;
    font-size: 1.6rem;
    line-height: 1;
    font-weight: 500;
    transition: opacity 0.3s ease;
  }

  .fz-header__logo:hover {
    opacity: 0.75;
  }

  .fz-header__logo img {
    width: auto;
    max-width: 100%;
    display: block;
  }

  .fz-logo-svg {
    overflow: visible;
  }

  .fz-header__nav {
    justify-self: center;
  }

  .fz-header__menu {
    display: flex;
    align-items: center;
    gap: 1.8rem;
  }

  .fz-header__menu a {
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color 250ms ease;
    position: relative;
    padding-bottom: 4px;
  }

  .fz-header__menu a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.3s ease;
  }

  .fz-header__menu a:hover::after,
  .fz-header__menu a[aria-current="page"]::after {
    width: 100%;
  }

  .fz-header__menu a:hover,
  .fz-header__menu a[aria-current="page"] {
    color: var(--color-accent);
  }

  .fz-header__right {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .fz-header__cart {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.85);
    position: relative;
    transition: color 180ms ease;
  }

  .fz-header__cart:hover {
    color: #a78bfa;
  }

  .fz-header__cart-count {
    position: absolute;
    top: -8px;
    right: -10px;
    min-width: 18px;
    min-height: 18px;
    background: linear-gradient(135deg, #8b5cf6, #6d28d9);
    border-radius: 999px;
    display: grid;
    place-items: center;
    font-size: 0.6rem;
    font-weight: 700;
    color: #fff;
    padding: 0 4px;
    line-height: 1;
  }

  .fz-header__menu-toggle {
    display: none;
    background: transparent;
    border: 0;
    padding: 4px;
    width: 1.8rem;
    cursor: pointer;
    flex-direction: column;
    gap: 4px;
  }

  .fz-header__menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: #ffffff;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  /* Mobile Drawer */
  .fz-mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 60;
    pointer-events: none;
  }

  .fz-mobile-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    opacity: 0;
    transition: opacity 200ms ease;
    backdrop-filter: blur(2px);
  }

  .fz-mobile-drawer__panel {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: min(88vw, 320px);
    background: #0a021a;
    border-right: 1px solid rgba(139, 92, 246, 0.2);
    transform: translateX(-100%);
    transition: transform 240ms ease;
    display: flex;
    flex-direction: column;
  }

  .fz-mobile-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 1.4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .fz-mobile-drawer__logo {
    display: flex;
    align-items: center;
  }

  .fz-mobile-drawer__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    color: #ffffff;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .fz-mobile-drawer__close:hover {
    background: rgba(139, 92, 246, 0.2);
  }

  .fz-mobile-drawer__menu {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.4rem;
    flex: 1;
  }

  .fz-mobile-drawer__menu a {
    display: flex;
    align-items: center;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: color 180ms ease, padding-left 200ms ease;
  }

  .fz-mobile-drawer__menu a:hover,
  .fz-mobile-drawer__menu a[aria-current="page"] {
    color: #a78bfa;
    padding-left: 8px;
  }

  .fz-mobile-drawer__footer {
    padding: 1.2rem 1.4rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .fz-mobile-drawer__cart-link {
    display: flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #6d28d9, #7c3aed);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 12px 20px;
    border-radius: 10px;
    justify-content: center;
    transition: filter 0.2s ease;
  }

  .fz-mobile-drawer__cart-link:hover {
    filter: brightness(1.1);
  }

  .menu-open .fz-mobile-drawer {
    pointer-events: auto;
  }

  .menu-open .fz-mobile-drawer__overlay {
    opacity: 1;
  }

  .menu-open .fz-mobile-drawer__panel {
    transform: translateX(0);
  }

  @media (max-width: 989px) {
    .fz-header__inner {
      grid-template-columns: 1fr auto;
      min-height: 66px;
    }

    .fz-header__menu-toggle {
      display: flex;
    }

    .fz-header__nav {
      display: none;
    }
  }
</style>

<script>
  (function () {
    var root = document.documentElement;
    var openBtn = document.querySelector("[data-menu-open]");
    var closeButtons = document.querySelectorAll("[data-menu-close]");

    if (!openBtn) return;

    var openMenu = function () { root.classList.add("menu-open"); };
    var closeMenu = function () { root.classList.remove("menu-open"); };

    openBtn.addEventListener("click", openMenu);
    closeButtons.forEach(function (button) {
      button.addEventListener("click", closeMenu);
    });

    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape") closeMenu();
    });

    var header = document.querySelector("[data-header]");
    var onScroll = function () {
      if (!header) return;
      var isVisible = window.scrollY > 80;
      header.classList.toggle("is-visible", isVisible);
      header.classList.toggle("is-scrolled", window.scrollY > 200);
    };

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    // Scroll reveal
    var reveals = document.querySelectorAll("[data-reveal]");
    if (reveals.length && typeof IntersectionObserver !== "undefined") {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      reveals.forEach(function(el) { observer.observe(el); });
    }
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 280,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 160
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
