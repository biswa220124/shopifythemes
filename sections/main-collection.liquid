<section class="fz-main-collection section">
  <div class="container">
    <div class="fz-main-collection__top">
      <h1>{{ collection.title }}</h1>

      <form class="fz-main-collection__sort-form" method="get">
        <label for="SortBy-{{ section.id }}">Sort by</label>
        <select id="SortBy-{{ section.id }}" name="sort_by" onchange="this.form.submit()">
          {% for option in collection.sort_options %}
            <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>
              {{ option.name }}
            </option>
          {% endfor %}
        </select>
      </form>
    </div>

    {% if collection.products_count > 0 %}
      <div class="fz-main-collection__grid">
        {% for product in collection.products %}
          <article class="fz-main-collection__card">
            <a href="{{ product.url }}" class="fz-main-collection__media">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 900 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  loading="lazy"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'fz-main-collection__placeholder' }}
              {% endif %}
            </a>

            <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
            <p class="fz-main-collection__price">{{ product.price | money }}</p>

            {% form 'product', product %}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button type="submit" {% unless product.available %}disabled{% endunless %}>
                {% if product.available %}Add to cart{% else %}Sold out{% endif %}
              </button>
            {% endform %}
          </article>
        {% endfor %}
      </div>
    {% else %}
      <p class="fz-main-collection__empty">No products found in this collection.</p>
    {% endif %}
  </div>
</section>

<style>
  .fz-main-collection {
    background: #ececec;
    color: #111111;
  }
  .fz-main-collection__top {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }
  .fz-main-collection__top h1 {
    margin: 0;
    font-family: "Bebas Neue", "Arial Narrow", sans-serif;
    font-size: clamp(2rem, 6vw, 3.8rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .fz-main-collection__sort-form {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .fz-main-collection__sort-form label {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .fz-main-collection__sort-form select {
    min-height: 2.4rem;
    border: 1px solid #111111;
    background: transparent;
    color: #111111;
    padding: 0.35rem 0.55rem;
  }
  .fz-main-collection__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.2rem;
  }
  .fz-main-collection__card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .fz-main-collection__media {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    display: block;
    background: #ddd;
  }
  .fz-main-collection__media img,
  .fz-main-collection__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 320ms ease;
  }
  .fz-main-collection__media:hover img {
    transform: scale(1.05);
  }
  .fz-main-collection__card h3 {
    margin: 0;
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
  }
  .fz-main-collection__card h3 a {
    color: #111111;
    text-decoration: none;
  }
  .fz-main-collection__price {
    margin: 0;
    color: #ff4500;
    font-weight: 600;
  }
  .fz-main-collection__card form button {
    width: 100%;
    min-height: 2.55rem;
    border: 1px solid #111111;
    background: transparent;
    color: #111111;
    font-size: 0.72rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 180ms ease, color 180ms ease, border-color 180ms ease;
  }
  .fz-main-collection__card form button:hover {
    background: #ff4500;
    border-color: #ff4500;
    color: #ffffff;
  }
  .fz-main-collection__card form button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .fz-main-collection__empty {
    margin: 0;
  }
  @media (max-width: 989px) {
    .fz-main-collection__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 749px) {
    .fz-main-collection__top {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

{% schema %}
{
  "name": "Main collection",
  "settings": []
}
{% endschema %}
