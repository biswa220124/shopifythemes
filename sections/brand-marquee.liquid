<section class="fz-brand-marquee {% if section.settings.padding_top %}fz-pt{% endif %}">
  <div class="fz-brand-marquee__container" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; padding-block: {{ section.settings.padding_y }}px;">
    <div class="fz-brand-marquee__track">
      {% for i in (1..10) %}
        <div class="fz-brand-marquee__item">
          <span class="fz-brand-marquee__text">{{ section.settings.text | default: "PREMIUM STREETWEAR" }}</span>
          <span class="fz-brand-marquee__separator"></span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.fz-brand-marquee {
  width: 100%;
  overflow: hidden;
  position: relative;
  z-index: 10;
  border-top: 1px solid rgba(255,255,255,0.05);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.fz-brand-marquee__container {
  display: flex;
  overflow: hidden;
  white-space: nowrap;
}

.fz-brand-marquee__track {
  display: flex;
  align-items: center;
  animation: marquee-scroll 25s linear infinite;
  will-change: transform;
}

.fz-brand-marquee__item {
  display: flex;
  align-items: center;
  padding: 0 2vw;
}

.fz-brand-marquee__text {
  font-family: var(--font-heading, "Playfair Display", serif);
  font-size: clamp(1rem, 2vw, 1.4rem);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 500;
  opacity: 0.9;
}

.fz-brand-marquee__separator {
  display: inline-block;
  width: 8px;
  height: 8px;
  background-color: var(--color-accent, #d4af37);
  border-radius: 50%;
  margin-left: 4vw;
  opacity: 0.8;
}

@keyframes marquee-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
</style>

{% schema %}
{
  "name": "Brand Marquee",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Scroll Text",
      "default": "FREE WORLDWIDE SHIPPING ON ALL ORDERS OVER £150"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#050507"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 18
    }
  ],
  "presets": [
    {
      "name": "Brand Marquee"
    }
  ]
}
{% endschema %}
