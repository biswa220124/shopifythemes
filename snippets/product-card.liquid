{% if product != blank %}
  <article class="fz-product-card">
    <a class="fz-product-card__media" href="{{ product.url }}">
      {% if product.featured_image %}
        <img
          src="{{ product.featured_image | image_url: width: 900 }}"
          alt="{{ product.featured_image.alt | escape | default: product.title }}"
          loading="lazy"
          class="fz-product-card__image"
        >
      {% else %}
        <div class="fz-product-card__image-placeholder">No image</div>
      {% endif %}

      {% if product.compare_at_price > product.price %}
        {% assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
        <div class="fz-product-card__badge">{{ savings }}% OFF</div>
      {% endif %}
    </a>

    <div class="fz-product-card__content">
      <h3 class="fz-product-card__title">
        <a href="{{ product.url }}">{{ product.title }}</a>
      </h3>

      <p class="fz-product-card__price">
        <span class="fz-product-card__price-current">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="fz-product-card__price-compare">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </p>

      {% form 'product', product, class: 'fz-product-card__form' %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button
          type="submit"
          class="fz-product-card__button"
          {% unless product.available %}disabled{% endunless %}
        >
          {% if product.available %}
            Add to cart
          {% else %}
            Sold out
          {% endif %}
        </button>
      {% endform %}
    </div>
  </article>

  <style>
    .fz-product-card {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      color: #111;
    }

    .fz-product-card__media {
      position: relative;
      display: block;
      overflow: hidden;
      aspect-ratio: 3 / 4;
      background: #f3f3f3;
      text-decoration: none;
    }

    .fz-product-card__image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 420ms ease;
    }

    .fz-product-card__media:hover .fz-product-card__image {
      transform: scale(1.07);
    }

    .fz-product-card__image-placeholder {
      display: grid;
      place-items: center;
      height: 100%;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #666;
    }

    .fz-product-card__content {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }

    .fz-product-card__title {
      margin: 0;
      font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
      font-size: 0.95rem;
      font-weight: 500;
      line-height: 1.4;
      letter-spacing: 0.02em;
    }

    .fz-product-card__title a {
      color: inherit;
      text-decoration: none;
    }

    .fz-product-card__price {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      margin: 0;
      font-size: 0.88rem;
    }

    .fz-product-card__price-current {
      font-weight: 700;
      color: #7c3aed;
    }

    .fz-product-card__price-compare {
      color: #777;
      text-decoration: line-through;
      font-size: 0.82rem;
    }

    .fz-product-card__form {
      margin-top: 0.15rem;
    }

    .fz-product-card__button {
      width: 100%;
      min-height: 2.75rem;
      padding: 0.72rem 1rem;
      border: 1px solid #111;
      background: transparent;
      color: #111;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background-color 180ms ease, color 180ms ease, border-color 180ms ease, opacity 180ms ease;
    }

    .fz-product-card__button:hover {
      background: linear-gradient(135deg, #7c3aed, #6d28d9);
      border-color: #7c3aed;
      color: #fff;
      transform: translateY(-1px);
    }

    .fz-product-card__badge {
      position: absolute;
      top: 12px;
      left: 12px;
      background: linear-gradient(135deg, #7c3aed, #6d28d9);
      color: #fff;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 20px;
      z-index: 1;
    }

    .fz-product-card__button:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }
  </style>
{% endif %}
